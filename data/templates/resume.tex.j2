\documentclass[10pt]{article}
\usepackage[letterpaper,top=0.5in,bottom=0.4in,left=0.6in,right=0.6in]{geometry}
\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc}
\usepackage{lmodern}
% protrusion=true works with tectonic (XeTeX); expansion=true does not.
\usepackage[protrusion=true,final]{microtype}
\usepackage{ragged2e}
\usepackage{enumitem}
\usepackage{tabularx}
\usepackage{titlesec}
\usepackage[hidelinks]{hyperref}

% ---- Orphan-line defense ----
% Default \tolerance=200 and \emergencystretch=0pt force the line-breaker to
% pick "early break + short wrap" over "stretch previous line a bit", which
% produces single-word orphan lines on line 2. We raise tolerance and grant
% 3em of emergency slack so 1-3 words of overflow absorb into the previous
% line instead of orphaning. Combined with ragged2e's \RaggedRight inside
% itemize and the skills/coursework blocks, this eliminates orphans without
% sacrificing readability. Never remove these — see CLAUDE.md.
\tolerance=2000
\emergencystretch=3em
\hyphenpenalty=1000
\exhyphenpenalty=1000
\hbadness=10000

\pagestyle{empty}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0pt}
\setlength{\tabcolsep}{0pt}
\setlength{\lineskip}{0pt}

% Section formatting
\titleformat{\section}{\bfseries\large}{}{0pt}{}[\vspace{0.15em}\hrule]
\titlespacing*{\section}{0pt}{<< section_space_before >>}{<< section_space_after >>}

% List formatting — bullets are JUSTIFIED (not ragged) so that
% \emergencystretch=3em above can stretch inter-word space on the previous
% line to absorb 1-3 words of overflow instead of orphaning them on line 2.
% Ragged itemize text defeats emergencystretch (ragged uses fixed spacing),
% so we keep bullets justified here and only use \RaggedRight on the skills
% and coursework paragraphs (which are capped structurally instead).
\setlist[itemize]{leftmargin=1.15em,topsep=<< item_topsep >>,itemsep=<< item_itemsep >>,parsep=0em}

\newcommand{\resumeHeader}[4]{%
  \begin{center}
    {\Large\bfseries #1}\par
    \vspace{0.15em}
    {\small #2 \;|\; #3 \;|\; #4}\par
  \end{center}
  \vspace{0.15em}
}

\newcommand{\entry}[4]{%
  \textbf{#1}\hfill \textbf{#2}\par
  \textit{#3}\hfill \textit{#4}\par
}

\newcommand{\entryEdu}[5]{%
  \textbf{#1}\hfill \textbf{#2}\par
  \textit{#3}\hfill {\small #5}\par
}

\begin{document}

\resumeHeader
  {<< meta.name >>}
  {<< meta.location >> \;|\; << meta.phone >> \;|\; \href{mailto:<< meta.email >>}{<< meta.email >>}}
  {\href{<< meta.linkedin >>}{LinkedIn}}
  {\href{<< meta.github >>}{GitHub}}

<% for section in section_order %>
<% include 'sections/' + section + '.tex.j2' %>
<% endfor %>

\end{document}
